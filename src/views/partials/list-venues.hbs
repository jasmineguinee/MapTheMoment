<table class="table is-fullwidth">
  <thead>
    <tr>
      <th>Venue</th>
      <th>Venue Type</th>
      <th>Description</th>
      <th>Latitude</th>
      <th>Longitude</th>
      <th>visability</th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    {{#each area.venues}}
      <tr>
        <td>
          {{title}}
        </td>
        <td>
          {{venuetype}}
        </td>
        <td>
          {{description}}
        </td>
         <td>
          {{latitude}}
        </td>
         <td>
          {{longitude}}
        </td>
         <td>
          {{visability}}
        </td>
         <td>
          <a href="/venue/{{../area._id}}/editvenue/{{_id}}" class="ui icon button">
            <i class="fas fa-edit"></i>
          </a>
        </td>
         <td>
          <a href="/area/{{../area._id}}/deletevenue/{{_id}}" class="ui icon button">
            <i class="fas fa-trash"></i>
          </a>
        </td>
      </tr>
    {{/each}}
  </tbody>
</table>

