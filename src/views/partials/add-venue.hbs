    
    
  <div class="box box-link-hover-shadow">
  <div hidden="hidden" id="weddingVenuesStrings">{{{weddingVenuesStrings}}}</div>
  <div hidden="hidden" id="proposalVenueStrings">{{{proposalVenueStrings}}}</div>

  <script>
    const map = L.map("map").setView([51.8985, -8.84756], 7); // [lat, lng], zoom
     L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
    attribution: "© OpenStreetMap contributors"
     }).addTo(map);

    map.dragging.enable();
    

    const rawWeddingVenues = document.getElementById("weddingVenuesStrings").textContent;
    const weddingVenues = JSON.parse(rawWeddingVenues);
    const rawProposalVenues = document.getElementById("proposalVenueStrings").textContent;
    const proposalVenues = JSON.parse(rawProposalVenues);

    
    const weddingicon = L.icon({
    iconUrl: "/images/dome.png",
    iconSize: [48, 48],
    iconAnchor: [16, 32],
    popupAnchor: [0, -32],
    });

    const proposalicon = L.icon({
    iconUrl: "/images/mappin.png",
    iconSize: [48, 48],
    iconAnchor: [16, 32],
    popupAnchor: [0, -32],
    });
    
    const markers = [];
    
    weddingVenues.forEach(venue => {
    L.popup()
    .setLatLng([venue.latitude, venue.longitude])
     marker = L.marker([venue.latitude, venue.longitude], { icon: weddingicon }).addTo(map);
     marker.bindPopup(venue.title + '<br Venue Type: >' + venue.venuetype + '<br> Description: ' + venue.description + '<br> + Latitude: ' + venue.latitude.toFixed(6) + '<br> Longitude: ' + venue.longitude.toFixed(6) + '<br> visability: ' + venue.visability);
     markers.push(marker)
     });

    proposalVenues.forEach(venue => {
    L.popup()
    .setLatLng([venue.latitude, venue.longitude])
     marker = L.marker([venue.latitude, venue.longitude], { icon: proposalicon }).addTo(map);
     marker.bindPopup(venue.title + '<br Venue Type: >' + venue.venuetype + '<br> Description: ' + venue.description + '<br> + Latitude: ' + venue.latitude.toFixed(6) + '<br> Longitude: ' + venue.longitude.toFixed(6) + '<br> visability: ' + venue.visability);
     markers.push(marker)
     });


    

    //https://leafletjs.com/reference.html#event-objects event object click
    map.on('click', function(ev) {
    const latitude = ev.latlng.lat; 
    const longitude = ev.latlng.lng;

  //setting the value of the id elements I will be needing on html side - brings it back to html
     document.getElementById("latitude").value = latitude.toFixed(6);
     document.getElementById("longitude").value = longitude.toFixed(6);
    
    L.popup()
    .setLatLng([latitude, longitude])
    .setContent('Choose this location! <br>'+'Latitude: ' + latitude.toFixed(6) + '<br>Longitude: ' + longitude.toFixed(6))
    .openOn(map);


    });
    
  </script>

  </div>
  <form class="box" action="/area/{{area._id}}/addvenue" method="POST">
  <label>Enter Venue Details. Click on the map to add a location for your venue</label>
  <div class="field is-horizontal">
    <div class="field-body">
      <div class="field">
        <input class="input" type="text" placeholder="Enter Title" name="title">
      </div>
      <div class="field">
        <select class="input" type="text" placeholder="Enter Venue Type" name="venuetype">
          <option value="proposal">proposal</option>
          <option value="wedding">wedding</option>
        </select>
      </div>
      
      <div class="field">
        <input class="input" type="text" placeholder="Enter description" name="description">
      </div>
      <div class="field">
        <input class="input" id="latitude" type="text" placeholder="Enter latitude" name="latitude">
      </div>
      <div class="field">
        <input class="input" id="longitude" type="text" placeholder="Enter longitude" name="longitude">
      </div>
      <div class="field">
        <select class="input" type="text" placeholder="make this public?" name="visability">
          <option value="public">public</option>
          <option value="private">private</option>
        </select>
      </div>
    </div>
  </div>
  <button class="button is-info">Add Venue</button>
</form>
